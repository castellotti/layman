#!/usr/bin/env bash
# Layman hook — Codex PostToolUse
# Forwards the event to the Layman server (fire-and-forget).

INPUT=$(cat)

if command -v jq > /dev/null 2>&1; then
  BODY=$(echo "$INPUT" | jq -c '. + {agent_type: "codex"}' 2>/dev/null)
fi
if [ -z "$BODY" ]; then
  BODY=$(echo "$INPUT" | sed 's/^{/{"agent_type":"codex",/')
fi

curl -s -m 5 -X POST "__LAYMAN_URL__/hooks/PostToolUse" \
  -H "Content-Type: application/json" \
  -d "$BODY" > /dev/null 2>&1

exit 0
